# onetrickle environment file.
# Copy to /etc/onetrickle/onetrickle.env, edit, and lock it down:
#   sudo install -D -m 600 -o onetrickle -g onetrickle \
#        deploy/onetrickle.env.example /etc/onetrickle/onetrickle.env
#
# Both variables must be set to require login. Leaving them empty serves the
# app with no authentication (only do that on a trusted private network).

ONETRICKLE_AUTH_USER=admin
ONETRICKLE_AUTH_PASS=change-me-to-a-long-random-string
